CHATGPT_RELAY_PORT=8787
CHATGPT_RELAY_PROFILE=default
CHATGPT_RELAY_EXTENSION_BROWSER=edge

# Optional Windows/WSL path overrides.
# CHATGPT_RELAY_WINDOWS_BROWSER_PROFILES=/mnt/c/Users/<you>/AppData/Local/chatgpt-web-relay/browser-profiles
# CHATGPT_RELAY_WINDOWS_EXTENSION_DIR=/mnt/c/Users/<you>/AppData/Local/chatgpt-web-relay/extension
# CHATGPT_RELAY_WINDOWS_EDGE=/mnt/c/Program Files (x86)/Microsoft/Edge/Application/msedge.exe
# CHATGPT_RELAY_WINDOWS_CHROME=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
